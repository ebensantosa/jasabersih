legacy-peer-deps=true
confirm-modules-purge=false

# React Native / Expo compat: hoist HANYA package yg Metro bundler butuh
# (gak bisa resolve dari .pnpm/ store). Sisanya tetap symlink default - sehemat mungkin
# file operation biar Windows Defender gak ganggu install di lokal.
public-hoist-pattern[]=*react-native-css-interop*
public-hoist-pattern[]=*nativewind*
public-hoist-pattern[]=react-native*
public-hoist-pattern[]=expo*
public-hoist-pattern[]=@react-native*
public-hoist-pattern[]=@expo*
