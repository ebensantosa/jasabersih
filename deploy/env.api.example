# Copy ke apps/api/.env di VPS
NODE_ENV=production
PORT=3000

# Postgres — ganti password
DATABASE_URL=postgresql://jasabersih:GANTI_PASSWORD@localhost:5432/jasabersih?schema=public

REDIS_URL=redis://localhost:6379

# Generate dengan: openssl rand -base64 64
JWT_ACCESS_SECRET=GANTI_DENGAN_RANDOM_64_CHAR
JWT_REFRESH_SECRET=GANTI_DENGAN_RANDOM_64_CHAR_BERBEDA
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_WINDOW_SECONDS=900

# Sprint 2 — saat siap go-live
ZENZIVA_USER_KEY=
ZENZIVA_PASS_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
