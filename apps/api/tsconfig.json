{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@jasabersih/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@jasabersih/shared-types/*": ["../../packages/shared-types/src/*"]
    }
  },
  "include": ["src/**/*", "prisma/seed.ts", "test/**/*"]
}
