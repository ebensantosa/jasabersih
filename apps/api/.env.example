NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://jasabersih:dev_password@localhost:5432/jasabersih_dev?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-with-strong-random-secret-min-64-chars
JWT_REFRESH_SECRET=replace-with-different-strong-random-secret-min-64-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_WINDOW_SECONDS=900

# CORS — comma-separated origins for browser clients (dashboard, mobile web)
CORS_ORIGINS=https://dashboard.jasabersih.com,http://localhost:3001,http://localhost:8081

# Cloudflare R2 (S3-compatible) — file storage for KYC, dispute evidence, public CDN
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_PRIVATE=jasabersih-private
R2_BUCKET_PUBLIC=jasabersih-public
R2_PUBLIC_BASE_URL=https://cdn.jasabersih.com

# Sprint 2 — placeholder
ZENZIVA_USER_KEY=
ZENZIVA_PASS_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Tripay (payment gateway)
# Sandbox: https://tripay.co.id/simulator (use https://tripay.co.id/api-sandbox)
# Production: https://tripay.co.id/api
TRIPAY_BASE_URL=https://tripay.co.id/api-sandbox
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
