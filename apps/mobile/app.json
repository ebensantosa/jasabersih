{
  "expo": {
    "name": "JasaBersih",
    "slug": "jasabersih-app",
    "version": "1.1.0",
    "scheme": "jasabersih",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jasabersih.app",
      "buildNumber": "2"
    },
    "android": {
      "package": "com.jasabersih.app",
      "versionCode": 2,
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1E40AF",
          "resizeMode": "contain",
          "imageWidth": 180
        }
      ]
    ],
    "experiments": { "typedRoutes": false },
    "extra": {
      "apiBaseUrl": "https://api.jasabersih.com/v1",
      "eas": {
        "projectId": "4ceb9dcf-a9bb-4125-b71e-3d3020c3ca4a"
      }
    },
    "owner": null
  }
}
