{
  "expo": {
    "name": "JasaBersih",
    "slug": "jasabersih-app",
    "version": "1.3.0",
    "scheme": "jasabersih",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jasabersih.app",
      "buildNumber": "13",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.jasabersih.app",
      "versionCode": 14,
      "edgeToEdgeEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0EA5E9",
          "resizeMode": "contain",
          "imageWidth": 0
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "JasaBersih perlu akses galeri untuk upload foto kondisi rumah.",
          "cameraPermission": "JasaBersih perlu akses kamera untuk ambil foto kondisi rumah langsung."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiBaseUrl": "https://api.jasabersih.com/v1",
      "eas": {
        "projectId": "4ceb9dcf-a9bb-4125-b71e-3d3020c3ca4a"
      }
    },
    "owner": "ebensantosa"
  }
}
